# ------------------------------------------------------------------
# Settings Route
# ------------------------------------------------------------------
@app.route('/admin/settings', methods=['GET', 'POST'])
def admin_settings():
    """
    Admin settings - Configure site settings.
    """
    if not session.get('admin'):
        return redirect(url_for('login'))
    
    lang = get_lang()
    t = TEXTS.get(lang, TEXTS['am'])
    
    # Get current settings from database
    current_settings = {}
    try:
        conn = get_db()
        cursor = conn.cursor()
        cursor.execute("SELECT key, value FROM settings")
        for row in cursor.fetchall():
            current_settings[row[0]] = row[1]
        conn.close()
    except:
        pass
    
    if request.method == 'POST':
        try:
            # Get settings from form
            whatsapp_number = request.form.get('whatsapp_number', '251906020606')
            shipping_threshold = request.form.get('shipping_threshold', '5000')
            shipping_cost = request.form.get('shipping_cost', '200')
            site_name = request.form.get('site_name', 'Ethiosadat Furniture')
            site_email = request.form.get('site_email', 'info@ethiosadat.com')
            
            conn = get_db()
            cursor = conn.cursor()
            
            # Update or insert settings
            settings_data = [
                ('whatsapp_number', whatsapp_number),
                ('free_shipping_threshold', shipping_threshold),
                ('shipping_cost', shipping_cost),
                ('site_name', site_name),
                ('site_email', site_email)
            ]
            
            for key, value in settings_data:
                cursor.execute("INSERT OR REPLACE INTO settings (key, value) VALUES (?, ?)", (key, value))
            
            conn.commit()
            conn.close()
            
            # Update environment variables for current session
            os.environ['WHATSAPP_NUMBER'] = whatsapp_number
            os.environ['FREE_SHIPPING_THRESHOLD'] = shipping_threshold
            os.environ['SHIPPING_COST'] = shipping_cost
            
            app.logger.info("Admin settings updated")
            flash('Settings saved successfully!', 'success')
            return redirect(url_for('admin_settings'))
            
        except Exception as e:
            app.logger.error(f"Error saving settings: {str(e)}")
            flash('Error saving settings.', 'error')
    
    # GET request - show settings form with current values
    return render_template('admin/settings.html', 
                           settings=current_settings,
                           whatsapp_number=current_settings.get('whatsapp_number', '251906020606'),
                           free_shipping_threshold=current_settings.get('free_shipping_threshold', '5000'),
                           shipping_cost=current_settings.get('shipping_cost', '200'),
                           lang=lang, t=t)  
# ==================== 10. 📬 API ROUTES (for AJAX calls) ====================

# ------------------------------------------------------------------
# API: Get Products (JSON)
# ------------------------------------------------------------------
@app.route('/api/products')
def api_products():
    """
    API endpoint to get all products in JSON format.
    Supports optional category filtering.
    
    Query Parameters:
        category (str, optional): Filter by category
        limit (int, optional): Limit number of results
    """
    try:
        category = request.args.get('category', '')
        limit = request.args.get('limit', 100, type=int)
        
        conn = get_db()
        cursor = conn.cursor()
        
        if category and category != 'all' and category != 'All':
            cursor.execute("""
                SELECT id, name_am, name_en, price, old_price, image, category 
                FROM products 
                WHERE category = ? 
                ORDER BY id DESC LIMIT ?
            """, (category, limit))
        else:
            cursor.execute("""
                SELECT id, name_am, name_en, price, old_price, image, category 
                FROM products 
                ORDER BY id DESC LIMIT ?
            """, (limit,))
        
        products = cursor.fetchall()
        conn.close()
        
        # Convert to list of dictionaries
        products_list = []
        for p in products:
            image_url = url_for('static', filename=f'uploads/{p[5]}') if p[5] and p[5] != '' else ''
            products_list.append({
                'id': p[0],
                'name_am': p[1],
                'name_en': p[2],
                'price': p[3],
                'old_price': p[4] if len(p) > 4 else None,
                'image': image_url,
                'category': p[6] if len(p) > 6 else ''
            })
        
        app.logger.info(f"API: Products fetched - {len(products_list)} items")
        
        return jsonify({
            'success': True,
            'products': products_list,
            'count': len(products_list)
        })
        
    except Exception as e:
        app.logger.error(f"API Error fetching products: {str(e)}")
        return jsonify({
            'success': False,
            'error': 'Failed to fetch products',
            'message': str(e)
        }), 500


# ------------------------------------------------------------------
# API: Get Single Product (JSON)
# ------------------------------------------------------------------
@app.route('/api/product/<int:product_id>')
def api_product(product_id):
    """
    API endpoint to get a single product in JSON format.
    
    Args:
        product_id (int): Product ID
    """
    try:
        conn = get_db()
        cursor = conn.cursor()
        cursor.execute("""
            SELECT id, name_am, name_en, price, old_price, image, category 
            FROM products WHERE id = ?
        """, (product_id,))
        
        product = cursor.fetchone()
        conn.close()
        
        if not product:
            return jsonify({
                'success': False,
                'error': 'Product not found'
            }), 404
        
        image_url = url_for('static', filename=f'uploads/{product[5]}') if product[5] and product[5] != '' else ''
        
        product_data = {
            'id': product[0],
            'name_am': product[1],
            'name_en': product[2],
            'price': product[3],
            'old_price': product[4] if len(product) > 4 else None,
            'image': image_url,
            'category': product[6] if len(product) > 6 else ''
        }
        
        app.logger.info(f"API: Product fetched - ID {product_id}")
        
        return jsonify({
            'success': True,
            'product': product_data
        })
        
    except Exception as e:
        app.logger.error(f"API Error fetching product {product_id}: {str(e)}")
        return jsonify({
            'success': False,
            'error': 'Failed to fetch product',
            'message': str(e)
        }), 500


# ------------------------------------------------------------------
# API: Get Cart Information (JSON)
# ------------------------------------------------------------------
@app.route('/api/cart')
def api_cart():
    """
    API endpoint to get current cart contents in JSON format.
    """
    try:
        cart = session.get('cart', [])
        
        cart_items = []
        subtotal = 0
        
        for item in cart:
            item_total = item.get('price', 0) * item.get('quantity', 1)
            subtotal += item_total
            cart_items.append({
                'id': item.get('id'),
                'name': item.get('name'),
                'price': item.get('price', 0),
                'quantity': item.get('quantity', 1),
                'image': item.get('image', ''),
                'total': item_total
            })
        
        threshold = int(os.environ.get('FREE_SHIPPING_THRESHOLD', '5000'))
        shipping_cost = int(os.environ.get('SHIPPING_COST', '200'))
        shipping = 0 if subtotal >= threshold else shipping_cost
        total = subtotal + shipping
        cart_count = sum(item.get('quantity', 1) for item in cart)
        
        return jsonify({
            'success': True,
            'cart': cart_items,
            'count': cart_count,
            'subtotal': subtotal,
            'shipping': shipping,
            'total': total
        })
        
    except Exception as e:
        app.logger.error(f"API Error fetching cart: {str(e)}")
        return jsonify({
            'success': False,
            'error': 'Failed to fetch cart',
            'message': str(e)
        }), 500


# ------------------------------------------------------------------
# API: Add to Cart (AJAX)
# ------------------------------------------------------------------
@app.route('/api/cart/add', methods=['POST'])
def api_add_to_cart():
    """
    API endpoint to add item to cart via AJAX.
    Expects JSON payload with product details.
    """
    try:
        # Get JSON data from request
        data = request.get_json()
        
        if not data:
            return jsonify({
                'success': False,
                'error': 'No data provided'
            }), 400
        
        product_id = str(data.get('product_id'))
        product_name = data.get('product_name')
        product_price = float(data.get('product_price', 0))
        product_image = data.get('product_image', '')
        quantity = int(data.get('quantity', 1))
        
        # Validate
        if not product_id or not product_name or product_price <= 0:
            return jsonify({
                'success': False,
                'error': 'Invalid product information'
            }), 400
        
        if quantity < 1:
            quantity = 1
        
        # Get current cart
        cart = session.get('cart', [])
        
        # Check if product already exists
        found = False
        for item in cart:
            if str(item.get('id')) == product_id:
                item['quantity'] += quantity
                found = True
                break
        
        # Add new item if not found
        if not found:
            cart.append({
                'id': product_id,
                'name': product_name,
                'price': product_price,
                'quantity': quantity,
                'image': product_image
            })
        
        # Save cart
        session['cart'] = cart
        session.modified = True
        
        # Calculate new cart count
        cart_count = sum(item.get('quantity', 1) for item in cart)
        
        app.logger.info(f"API: Added to cart - {product_name} x{quantity}")
        
        return jsonify({
            'success': True,
            'message': f'{product_name} added to cart!',
            'cart_count': cart_count
        })
        
    except Exception as e:
        app.logger.error(f"API Error adding to cart: {str(e)}")
        return jsonify({
            'success': False,
            'error': 'Failed to add to cart',
            'message': str(e)
        }), 500


# ------------------------------------------------------------------
# API: Update Cart Item (AJAX)
# ------------------------------------------------------------------
@app.route('/api/cart/update', methods=['POST'])
def api_update_cart():
    """
    API endpoint to update cart item quantity via AJAX.
    """
    try:
        data = request.get_json()
        
        if not data:
            return jsonify({
                'success': False,
                'error': 'No data provided'
            }), 400
        
        product_id = str(data.get('product_id'))
        quantity = int(data.get('quantity', 1))
        
        if not product_id:
            return jsonify({
                'success': False,
                'error': 'Product ID required'
            }), 400
        
        if quantity < 1:
            quantity = 1
        
        # Get current cart
        cart = session.get('cart', [])
        
        # Update quantity
        item_found = None
        for item in cart:
            if str(item.get('id')) == product_id:
                item['quantity'] = quantity
                item_found = item
                break
        
        if not item_found:
            return jsonify({
                'success': False,
                'error': 'Item not found in cart'
            }), 404
        
        # Save cart
        session['cart'] = cart
        session.modified = True
        
        # Calculate totals
        subtotal = 0
        for item in cart:
            subtotal += item.get('price', 0) * item.get('quantity', 1)
        
        threshold = int(os.environ.get('FREE_SHIPPING_THRESHOLD', '5000'))
        shipping_cost = int(os.environ.get('SHIPPING_COST', '200'))
        shipping = 0 if subtotal >= threshold else shipping_cost
        total = subtotal + shipping
        cart_count = sum(item.get('quantity', 1) for item in cart)
        item_total = item_found.get('price', 0) * quantity
        
        app.logger.info(f"API: Updated cart item - {item_found.get('name')} x{quantity}")
        
        return jsonify({
            'success': True,
            'message': 'Cart updated',
            'item_total': item_total,
            'subtotal': subtotal,
            'shipping': shipping,
            'total': total,
            'cart_count': cart_count
        })
        
    except Exception as e:
        app.logger.error(f"API Error updating cart: {str(e)}")
        return jsonify({
            'success': False,
            'error': 'Failed to update cart',
            'message': str(e)
        }), 500


# ------------------------------------------------------------------
# API: Remove from Cart (AJAX)
# ------------------------------------------------------------------
@app.route('/api/cart/remove', methods=['POST'])
def api_remove_from_cart():
    """
    API endpoint to remove item from cart via AJAX.
    """
    try:
        data = request.get_json()
        
        if not data:
            return jsonify({
                'success': False,
                'error': 'No data provided'
            }), 400
        
        product_id = str(data.get('product_id'))
        
        if not product_id:
            return jsonify({
                'success': False,
                'error': 'Product ID required'
            }), 400
        
        # Get current cart
        cart = session.get('cart', [])
        
        # Remove item
        removed_item = None
        new_cart = []
        for item in cart:
            if str(item.get('id')) == product_id:
                removed_item = item
            else:
                new_cart.append(item)
        
        if not removed_item:
            return jsonify({
                'success': False,
                'error': 'Item not found in cart'
            }), 404
        
        # Save cart
        session['cart'] = new_cart
        session.modified = True
        
        # Calculate new totals
        subtotal = 0
        for item in new_cart:
            subtotal += item.get('price', 0) * item.get('quantity', 1)
        
        threshold = int(os.environ.get('FREE_SHIPPING_THRESHOLD', '5000'))
        shipping_cost = int(os.environ.get('SHIPPING_COST', '200'))
        shipping = 0 if subtotal >= threshold else shipping_cost
        total = subtotal + shipping
        cart_count = sum(item.get('quantity', 1) for item in new_cart)
        
        app.logger.info(f"API: Removed from cart - {removed_item.get('name')}")
        
        return jsonify({
            'success': True,
            'message': f'{removed_item.get("name")} removed from cart',
            'subtotal': subtotal,
            'shipping': shipping,
            'total': total,
            'cart_count': cart_count
        })
        
    except Exception as e:
        app.logger.error(f"API Error removing from cart: {str(e)}")
        return jsonify({
            'success': False,
            'error': 'Failed to remove from cart',
            'message': str(e)
        }), 500


# ------------------------------------------------------------------
# API: Get Categories (JSON)
# ------------------------------------------------------------------
@app.route('/api/categories')
def api_categories():
    """
    API endpoint to get all product categories.
    """
    try:
        conn = get_db()
        cursor = conn.cursor()
        
        # Get distinct categories from products
        cursor.execute("SELECT DISTINCT category FROM products WHERE category IS NOT NULL AND category != '' ORDER BY category")
        categories_from_db = [row[0] for row in cursor.fetchall()]
        conn.close()
        
        # Default categories if none exist
        default_categories = ['ሶፋ', 'አልጋ', 'መጅሊስ', 'መጋረጃ', 'ቁምሳጥን', 'ሌላ']
        
        # Use categories from DB if any, otherwise use defaults
        categories = categories_from_db if categories_from_db else default_categories
        
        # Add 'all' option at the beginning
        all_categories = ['all'] + categories
        
        return jsonify({
            'success': True,
            'categories': all_categories
        })
        
    except Exception as e:
        app.logger.error(f"API Error fetching categories: {str(e)}")
        return jsonify({
            'success': False,
            'error': 'Failed to fetch categories',
            'message': str(e)
        }), 500


