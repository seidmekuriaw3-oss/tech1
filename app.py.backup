            'cart_count': cart_count
        })
        
    except Exception as e:
        app.logger.error(f"API Error fetching cart count: {str(e)}")
        return jsonify({
            'success': False,
            'error': 'Failed to fetch cart count',
            'cart_count': 0
        }), 500


# ------------------------------------------------------------------
# API: Search Products (JSON)
# ------------------------------------------------------------------
@app.route('/api/search')
def api_search():
    """
    API endpoint to search products by name.
    
    Query Parameters:
        q (str): Search query
    """
    try:
        query = request.args.get('q', '').strip()
        
        if not query:
            return jsonify({
                'success': True,
                'products': [],
                'count': 0
            })
        
        search_pattern = f'%{query}%'
        
        conn = get_db()
        cursor = conn.cursor()
        cursor.execute("""
            SELECT id, name_am, name_en, price, old_price, image, category 
            FROM products 
            WHERE name_am LIKE ? OR name_en LIKE ?
            ORDER BY id DESC
        """, (search_pattern, search_pattern))
        
        products = cursor.fetchall()
        conn.close()
        
        products_list = []
        for p in products:
            image_url = url_for('static', filename=f'uploads/{p[5]}') if p[5] and p[5] != '' else ''
            products_list.append({
                'id': p[0],
                'name_am': p[1],
                'name_en': p[2],
                'price': p[3],
                'old_price': p[4] if len(p) > 4 else None,
                'image': image_url,
                'category': p[6] if len(p) > 6 else ''
            })
        
        app.logger.info(f"API: Search performed - '{query}' found {len(products_list)} results")
        
        return jsonify({
            'success': True,
            'products': products_list,
            'count': len(products_list),
            'query': query
        })
        
    except Exception as e:
        app.logger.error(f"API Error searching: {str(e)}")
        return jsonify({
            'success': False,
            'error': 'Failed to search products',
            'message': str(e)
        }), 500
