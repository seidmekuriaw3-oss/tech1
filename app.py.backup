# Product Management Routes
# ---------------------------------------------@app.route('/admin/products')
def admin_products():
    """
    Admin product list - View all products with management options.
    """
    if not session.get('admin'):
        return redirect(url_for('login'))
    
    lang = get_lang()
    t = TEXTS.get(lang, TEXTS['am'])
    
    try:
        conn = get_db()
        # መረጃውን በስም ለመጥራት (ለምሳሌ product['price']) ይህ መስመር የግድ ያስፈልጋል
        conn.row_factory = sqlite3.Row 
        cursor = conn.cursor()
        cursor.execute("SELECT * FROM products ORDER BY id DESC")
        products = cursor.fetchall()
        conn.close()
        
        app.logger.info(f"Admin product list viewed - {len(products)} products")
        
        return render_template('admin/products/index.html',
                               products=products,
                               lang=lang,
                               t=t)
    
    except Exception as e:
