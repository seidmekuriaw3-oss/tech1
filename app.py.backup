    else:
        print(f"ℹ️ Ads already exist ({ad_count} ads), skipping demo ads")
    
    conn.commit()
    conn.close()
    
    print("🎉 Demo data seeding complete!")


@app.cli.command('list-products')
def list_products():
    """List all products in the database."""
    import sqlite3
    
    db_path = Config.DATABASE_PATH if hasattr(Config, 'DATABASE_PATH') else 'ethiosadat.db'
    
    conn = sqlite3.connect(db_path)
    cursor = conn.cursor()
    cursor.execute("SELECT id, name_am, name_en, price, category FROM products ORDER BY id")
    products = cursor.fetchall()
    conn.close()
    
    if not products:
        print("📭 No products found in database.")
        return
    
    print("\n" + "=" * 80)
    print(f"{'ID':<5} {'Name (Amharic)':<25} {'Name (English)':<20} {'Price':<12} {'Category':<15}")
    print("-" * 80)
    
    for product in products:
        print(f"{product[0]:<5} {product[1][:24]:<25} {product[2][:19]:<20} {product[3]:<12} {product[4][:14]:<15}")
    
    print("=" * 80)
    print(f"Total products: {len(products)}")


@app.cli.command('list-ads')
def list_ads():
    """List all advertisements."""
    import sqlite3
    
    db_path = Config.DATABASE_PATH if hasattr(Config, 'DATABASE_PATH') else 'ethiosadat.db'
    
    conn = sqlite3.connect(db_path)
    cursor = conn.cursor()
    cursor.execute("SELECT id, text, media FROM ads ORDER BY id")
    ads = cursor.fetchall()
    conn.close()
    
    if not ads:
        print("📭 No advertisements found.")
        return
    
    print("\n" + "=" * 80)
    print(f"{'ID':<5} {'Text':<50} {'Media':<20}")
    print("-" * 80)
    
    for ad in ads:
        text_preview = ad[1][:47] + "..." if len(ad[1]) > 50 else ad[1]
        media_status = "Has media" if ad[2] else "No media"
        print(f"{ad[0]:<5} {text_preview:<50} {media_status:<20}")
    
    print("=" * 80)
    print(f"Total ads: {len(ads)}")


@app.cli.command('clear-cache')
def clear_cache():
    """Clear cached data (temporary files, etc.)."""
    import shutil
    
    cache_dirs = ['logs', 'static/uploads/temp']
    deleted_count = 0
    
    print("🧹 Clearing cache...")
    
    for cache_dir in cache_dirs:
        if os.path.exists(cache_dir):
            for filename in os.listdir(cache_dir):
                file_path = os.path.join(cache_dir, filename)
                try:
                    if os.path.isfile(file_path):
                        os.unlink(file_path)
                        deleted_count += 1
                    elif os.path.isdir(file_path):
                        shutil.rmtree(file_path)
                        deleted_count += 1
                except Exception as e:
                    print(f"⚠️ Error deleting {file_path}: {e}")
    
    print(f"✅ Cache cleared! Deleted {deleted_count} items.")


@app.cli.command('backup-db')
def backup_database():
    """Create a backup of the database."""
    import shutil
    from datetime import datetime
    
    db_path = Config.DATABASE_PATH if hasattr(Config, 'DATABASE_PATH') else 'ethiosadat.db'
    
    if not os.path.exists(db_path):
        print("❌ Database file not found!")
        return
    
    # Create backup directory if not exists
    backup_dir = 'backups'
    os.makedirs(backup_dir, exist_ok=True)
    
    # Generate backup filename with timestamp
    timestamp = datetime.now().strftime('%Y%m%d_%H%M%S')
    backup_filename = f"ethiosadat_backup_{timestamp}.db"
    backup_path = os.path.join(backup_dir, backup_filename)
    
    # Copy database file
    shutil.copy2(db_path, backup_path)
    
    # Get file size
    size_bytes = os.path.getsize(backup_path)
    size_kb = size_bytes / 1024
    
    print(f"✅ Database backup created successfully!")
    print(f"   📁 Location: {backup_path}")
    print(f"   📊 Size: {size_kb:.2f} KB")
    print(f"   🕐 Time: {timestamp}")


@app.cli.command('show-stats')
def show_stats():
    """Show database statistics."""
    import sqlite3
    
    db_path = Config.DATABASE_PATH if hasattr(Config, 'DATABASE_PATH') else 'ethiosadat.db'
    
    conn = sqlite3.connect(db_path)
    cursor = conn.cursor()
    
    # Get counts
    cursor.execute("SELECT COUNT(*) FROM products")
    product_count = cursor.fetchone()[0]
    
    cursor.execute("SELECT COUNT(*) FROM ads")
    ad_count = cursor.fetchone()[0]
    
    cursor.execute("SELECT COUNT(*) FROM orders")
    order_count = cursor.fetchone()[0]
    
    # Get revenue
    cursor.execute("SELECT SUM(total) FROM orders WHERE status = 'delivered'")
    revenue = cursor.fetchone()[0] or 0
    
    # Get pending orders
    cursor.execute("SELECT COUNT(*) FROM orders WHERE status = 'pending'")
    pending_orders = cursor.fetchone()[0]
    
    # Get categories
    cursor.execute("SELECT COUNT(DISTINCT category) FROM products WHERE category IS NOT NULL")
    category_count = cursor.fetchone()[0]
    
    conn.close()
    
    print("\n" + "=" * 50)
    print("📊 ETHIOSADAT DATABASE STATISTICS")
    print("=" * 50)
    print(f"📦 Products:          {product_count}")
    print(f"📢 Advertisements:    {ad_count}")
    print(f"🛒 Orders:            {order_count}")
    print(f"💰 Total Revenue:     {revenue:,.0f} ETB")
    print(f"⏳ Pending Orders:    {pending_orders}")
    print(f"🏷️  Categories:        {category_count}")
    print("=" * 50)


@app.cli.command('create-admin')
def create_admin():
    """Create or update admin password (interactive)."""
    import getpass
    
    print("\n🔐 Admin Setup")
    print("-" * 30)
    
    # Get new admin password
    password = getpass.getpass("Enter admin password (min 4 characters): ")
    
    if len(password) < 4:
        print("❌ Password must be at least 4 characters!")
        return
    
    confirm = getpass.getpass("Confirm admin password: ")
    
    if password != confirm:
        print("❌ Passwords do not match!")
        return
    
    # Update .env or set environment variable
    env_file = '.env'
    
    if os.path.exists(env_file):
        # Update existing .env file
        with open(env_file, 'r') as f:
            lines = f.readlines()
        
        admin_updated = False
        with open(env_file, 'w') as f:
            for line in lines:
                if isinstance(line, str) and line.startswith('ADMIN_PASSWORD='):
                  f.write(f'ADMIN_PASSWORD={password}\n')
                  admin_updated = True
                else:
                    f.write(line)
            
            if not admin_updated:
                f.write(f'\nADMIN_PASSWORD={password}\n')
        
        print("✅ Admin password updated in .env file!")
    else:
        # Create new .env file
        with open(env_file, 'w') as f:
            f.write(f'ADMIN_PASSWORD={password}\n')
            f.write('SECRET_KEY=ethiosadat_default_secret_key_2026\n')
        print("✅ .env file created with admin password!")
    
    print("ℹ️  Please restart the application for changes to take effect.")


# ==================== 14. 🚀 MAIN ENTRY POINT ====================

def create_app():
    """Application factory pattern for creating the Flask app."""
    return app


def main():
    """Main entry point for running the application."""
    
    # Parse command line arguments for direct execution
    if len(sys.argv) > 1 and sys.argv[1] == 'init-db':
        init_db_command()
        return
    
    if len(sys.argv) > 1 and sys.argv[1] == 'seed':
        seed_demo_data()
        return
    
    # Get configuration from environment
    debug = os.environ.get('FLASK_DEBUG', 'False').lower() == 'true'
    port = int(os.environ.get('PORT', 5000))
    host = os.environ.get('HOST', '0.0.0.0')
    
    # Print startup banner
    print("\n" + "=" * 60)
    print("🪑 ETHIOSADAT FURNITURE STORE")
    print("=" * 60)
    print(f"🚀 Starting application...")
    print(f"📍 Host: {host}")
    print(f"🔌 Port: {port}")
    print(f"🐛 Debug Mode: {debug}")
    print(f"🌐 Language: {DEFAULT_LANGUAGE}")
    print("=" * 60)
    print("\n💡 Admin Panel Access:")
    print(f"   ➜ URL: http://{host}:{port}/login")
    print(f"   ➜ Password: {ADMIN_PASSWORD if ADMIN_PASSWORD != '1234' else '1234 (default)'}")
    print("\n📞 Customer WhatsApp:")
    print(f"   ➜ Number: {WHATSAPP_NUMBER}")
    print("\n" + "=" * 60)
    print("✅ Server is ready! Press CTRL+C to stop.")
    print("=" * 60 + "\n")
    
    # Run the Flask application
    app.run(host=host, port=port, debug=debug)


# ------------------------------------------------------------------
# WSGI Entry Point (for production servers like gunicorn)
# ------------------------------------------------------------------
# The 'app' variable is the WSGI callable
# For production: gunicorn -w 4 -b 0.0.0.0:8000 'app:app'

# ------------------------------------------------------------------
# Development Server Entry Point
# ------------------------------------------------------------------
if __name__ == '__main__':
    # Prompt for commands if run directly
    if len(sys.argv) <= 1 or sys.argv[1] not in ['init-db', 'seed']:
        # Check if database exists
        db_path = Config.DATABASE_PATH if hasattr(Config, 'DATABASE_PATH') else 'ethiosadat.db'
        if not os.path.exists(db_path):
            print("⚠️  Database not found! Running initialization...")
            init_db_command()
            print()
            seed_demo_data()
            print()
    
    main()


