# ==================== 12. 🔄 CONTEXT PROCESSORS ====================

# ------------------------------------------------------------------
# Global Context Processor
# ------------------------------------------------------------------
@app.context_processor
def inject_globals():
    """
    Inject global variables into all templates.
    """
    lang = get_lang()
    t = TEXTS.get(lang, TEXTS['am'])
    
    cart = session.get('cart', [])
    cart_count = sum(item.get('quantity', 1) for item in cart)
    
    current_year = datetime.now().year
    is_admin = session.get('admin', False)
    app_name = "Ethiosadat Furniture"
    whatsapp_number = os.environ.get('WHATSAPP_NUMBER', '251906020606')
    
    def _(key):
        return get_text(key, lang)
    
    def get_cart_total():
        total = 0
        for item in session.get('cart', []):
            total += item.get('price', 0) * item.get('quantity', 1)
        return total
    
    def get_shipping_cost():
        subtotal = get_cart_total()
        threshold = int(os.environ.get('FREE_SHIPPING_THRESHOLD', '5000'))
        cost = int(os.environ.get('SHIPPING_COST', '200'))
        return 0 if subtotal >= threshold else cost
    
    def get_grand_total():
        return get_cart_total() + get_shipping_cost()
    
    return {
        'current_year': current_year,
        'cart_count': cart_count,
        'lang': lang,
        't': t,
        '_': _,
        'is_admin': is_admin,
        'app_name': app_name,
        'whatsapp_number': whatsapp_number,
        'request': request,
        'get_cart_total': get_cart_total,
        'get_shipping_cost': get_shipping_cost,
        'get_grand_total': get_grand_total
    }


# ------------------------------------------------------------------
# Template Filters
# ------------------------------------------------------------------
@app.template_filter('format_price')
def format_price_filter(price):
    """
    Format price with thousand separators and ETB currency.
    Usage: {{ product.price|format_price }}
    """
    try:
        price_float = float(price)
        return f"{price_float:,.0f}".replace(',', ',') + " ETB"
    except (ValueError, TypeError):
        return f"{price} ETB"


@app.template_filter('format_number')
def format_number_filter(price):
    """
    Format price as number only (without currency).
    Usage: {{ product.price|format_number }}
    """
    try:
        price_float = float(price)
        return f"{price_float:,.0f}".replace(',', ',')
    except (ValueError, TypeError):
        return str(price)


@app.template_filter('truncate')
def truncate_filter(text, length=50):
    """
    Truncate text to specified length and add ellipsis.
    Usage: {{ product.description|truncate(100) }}
    """
    if not text:
        return ''
    if len(text) <= length:
        return text
    return text[:length].rstrip() + '...'


@app.template_filter('datetime')
def datetime_filter(dt):
    """
    Format datetime for display.
    Usage: {{ order.created_at|datetime }}
    """
    if not dt:
        return ''
    return dt.strftime('%Y-%m-%d %H:%M')


@app.template_filter('discount')
def discount_filter(price, old_price):
    """
    Calculate discount percentage.
    Usage: {{ product.price|discount(product.old_price) }}
    """
    try:
        current = float(price)
        original = float(old_price) if old_price else 0
        if original > 0 and current < original:
            return int(((original - current) / original) * 100)
        return 0
    except (ValueError, TypeError):
        return 0


@app.template_filter('format_date')
def format_date_filter(date_obj, format_type='short'):
    """
    Format date for display.
    Usage: {{ product.created_at|format_date('long') }}
    """
    if not date_obj:
        return ''
    
    if format_type == 'short':
        return date_obj.strftime('%d/%m/%Y')
    elif format_type == 'long':
        return date_obj.strftime('%B %d, %Y')
    else:
        return date_obj.strftime('%Y-%m-%d %H:%M:%S')


@app.template_filter('nl2br')
def nl2br_filter(text):
    """
    Convert newlines to HTML line breaks.
    Usage: {{ product.description|nl2br }}
    """
    if not text:
        return ''
    return text.replace('\n', '<br>')


@app.template_filter('default')
def default_filter(value, default_value=''):
    """
    Return default value if the primary value is empty/None.
    Usage: {{ product.old_price|default('No discount') }}
    """
    if value is None or value == '':
        return default_value
    return value


# ==================== ADDITIONAL FILTERS ====================

@app.template_filter('currency_symbol')
def currency_symbol_filter(price):
    """Return only the currency symbol (ETB)."""
    return "ETB"


@app.template_filter('safe_text')
def safe_text_filter(text):
    """Escape HTML special characters for safe display."""
    if not text:
        return ''
    import html
    return html.escape(str(text))


@app.template_filter('from_json')
def from_json_filter(json_str):
    """Parse JSON string to Python object."""
    if not json_str:
        return []
    try:
        return json.loads(json_str)
    except:
        return []


@app.template_filter('to_json')
def to_json_filter(obj):
    """Convert Python object to JSON string."""
    try:
        return json.dumps(obj)
    except:
        return '{}'


@app.template_filter('slugify')
def slugify_filter(text):
    """Convert text to URL-friendly slug."""
    if not text:
        return ''
    from utils.helpers import slugify
    return slugify(text)
