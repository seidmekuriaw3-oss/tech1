# ------------------------------------------------------------------
# Command Line Interface for Application Management
# ------------------------------------------------------------------
@app.cli.command('init-db')
def init_db_command():
    """ሁሉንም ሰንጠረዦች ከፎቶዎቹ ጋር በሚስማማ መልኩ መፍጠር"""
    import sqlite3
    db_path = 'ethiosadat.db'
    conn = sqlite3.connect(db_path)
    cursor = conn.cursor()
    
    # 1. Products Table (ከመጀመሪያው ፎቶ ጋር የሚጣጣም)
    cursor.execute('''
        CREATE TABLE IF NOT EXISTS products (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            name_am TEXT NOT NULL, name_en TEXT,
            description_am TEXT, description_en TEXT,
            price REAL NOT NULL, old_price REAL,
            category TEXT, stock_quantity INTEGER DEFAULT 0,
            is_featured INTEGER DEFAULT 0, image TEXT,
            meta_title TEXT, meta_description TEXT,
            created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
        )
    ''')

    # 2. Ads Table (ከ Advertisement ፎቶህ ጋር የሚጣጣም)
    cursor.execute('''
        CREATE TABLE IF NOT EXISTS ads (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            ad_text TEXT NOT NULL,
            title TEXT,
            link_url TEXT,
            media TEXT, -- Image or Video
            media_url TEXT, -- For Direct Media URL
            sort_order INTEGER DEFAULT 0,
            active INTEGER DEFAULT 1,
            created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
        )
    ''')

    # 3. Orders Table (ከ Order Management ፎቶህ ጋር የሚጣጣም)
    cursor.execute('''
        CREATE TABLE IF NOT EXISTS orders (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            order_number TEXT UNIQUE,
            customer_name TEXT NOT NULL,
            customer_phone TEXT NOT NULL,
            customer_address TEXT,
            customer_email TEXT,
            total REAL,
            status TEXT DEFAULT 'pending', -- pending, processing, shipped, etc.
            created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
        )
    ''')

    # 4. Settings Table (ከ Admin Settings ፎቶህ ጋር የሚጣጣም)
    cursor.execute('''
        CREATE TABLE IF NOT EXISTS settings (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            key TEXT UNIQUE NOT NULL,
            value TEXT
        )
    ''')

    # በፎቶህ ላይ ያየናቸው Settings በሙሉ እዚህ ይገባሉ
    default_settings = [
        ('site_name', 'Ethiosadat Furniture'),
        ('site_description', 'ጥራት ያለው የቤት እቃዎች በምቹ ዋጋ'),
        ('admin_email', 'admin@example.com'),
        ('whatsapp_number', '251906020606'),
        ('phone_number', '+251906020606'),
        ('store_address', 'Addis Ababa, Ethiopia'),
        ('free_shipping_threshold', '5000'),
        ('shipping_cost', '200'),
        ('currency', 'ETB'),
        ('default_lang', 'am'),
        ('meta_keywords', 'furniture, ethiosadat, addis ababa'),
        ('google_analytics_id', 'G-XXXXXXXXXX')
    ]
    
    for key, value in default_settings:
        cursor.execute('INSERT OR IGNORE INTO settings (key, value) VALUES (?, ?)', (key, value))
    
    conn.commit()
    conn.close()
    print("✅ ዳታቤዝህ ከሁሉም ገጾች ጋር ተጣጥሞ ተፈጥሯል!")

