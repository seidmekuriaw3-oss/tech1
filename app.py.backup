# Admin Logout Route
# ------------------------------------------------------------------
@app.route('/logout')
def logout():
    """
    Admin logout - Clears admin session and redirects to home page.
    """
    # Clear admin session
    if session.get('admin'):
        app.logger.info("Admin logged out")
        session.pop('admin', None)
        flash('You have been logged out successfully.', 'success')
    else:
        flash('You were not logged in.', 'info')
    
    return redirect(url_for('index'))


# ------------------------------------------------------------------
# Helper function to check if user is logged in
# ------------------------------------------------------------------
def is_admin():
    """
    Check if the current user is logged in as admin.
    
    Returns:
        bool: True if admin is logged in, False otherwise
    """
    return session.get('admin', False)


# ------------------------------------------------------------------
# Login Required Decorator (for routes that need admin access)
# ------------------------------------------------------------------
def login_required_manual(f):
    """
    Decorator to require admin login for routes.
    
    Usage:
        @app.route('/admin/protected')
        @login_required_manual
        def protected_page():
            return "Protected content"
    """
    @wraps(f)
    def decorated_function(*args, **kwargs):
        if not session.get('admin'):
            flash('Please log in to access this page.', 'warning')
            return redirect(url_for('login', next=request.url))
        return f(*args, **kwargs)
    return decorated_function


