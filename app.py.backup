# ------------------------------------------------------------------
# Admin Login Route
# ------------------------------------------------------------------
@app.route('/login', methods=['GET', 'POST'])
def login():
    """
    Admin login page - Authenticates admin user.
    GET: Display login form
    POST: Process login credentials
    """
    # If already logged in, redirect to admin dashboard
    if session.get('admin'):
        app.logger.info("User already logged in, redirecting to admin dashboard")
        return redirect(url_for('admin_dashboard'))
    
    # Get current language
    lang = get_lang()
    t = TEXTS.get(lang, TEXTS['am'])
    
    if request.method == 'POST':
        # Get password from form
        password = request.form.get('password', '').strip()
        
        # Validate password
        if not password:
            flash('Please enter your password.', 'error')
            return render_template('admin/login.html', error='Please enter your password.', lang=lang, t=t)
        
        # Check against admin password
        if password == ADMIN_PASSWORD:
            # Login successful
            session['admin'] = True
            session.permanent = True
            app.logger.info("Admin logged in successfully")
            
            flash('Welcome back, Admin!', 'success')
            
            # Redirect to admin dashboard
            next_page = request.args.get('next') or request.form.get('next')
            if next_page and isinstance(next_page, str) and next_page.startswith('/'):
                return redirect(next_page)
            return redirect(url_for('admin_dashboard'))
        else:
            # Login failed
            app.logger.warning(f"Failed login attempt from {request.remote_addr}")
            flash('Invalid password. Please try again.', 'error')
            return render_template('admin/login.html', error='Invalid password. Please try again.', lang=lang, t=t)
    
    # GET request - display login form
    return render_template('admin/login.html', lang=lang, t=t, error=None)


