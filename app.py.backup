        a{{display:inline-block;padding:10px 20px;border-radius:30px;text-decoration:none;}}
        .home{{background:#1a73e8;color:white;}}
        .login{{background:#f39c12;color:white;}}
    </style>
    </head>
    <body><div class="box"><h1>403</h1><p>{message}</p><div class="buttons"><a href="/" class="home">🏠 Home</a><a href="/login" class="login">🔐 Login</a></div></div></body>
    </html>
    ''', 403


# ==================== 6. 🏠 CUSTOMER ROUTES ====================

@app.route('/')
def index():
    """Home page - displays products and advertisements."""
    lang = get_lang()
    try:
        conn = get_db()
        cursor = conn.cursor()
        cursor.execute("SELECT * FROM products ORDER BY id DESC")
        items = cursor.fetchall()
        cursor.execute("SELECT * FROM ads ORDER BY id DESC")
        ads = cursor.fetchall()
        conn.close()
        return render_template('customer/index.html', items=items, ads=ads, lang=lang, t=TEXTS.get(lang, TEXTS['am']))
    except Exception as e:
        app.logger.error(f"Home page error: {str(e)}")
        return render_template('customer/index.html', items=[], ads=[], lang=lang, t=TEXTS.get(lang, TEXTS['am']))


@app.route('/product/<int:product_id>')
def product_detail(product_id):
    """Product detail page."""
    lang = get_lang()
    try:
        conn = get_db()
        cursor = conn.cursor()
        cursor.execute("SELECT * FROM products WHERE id = ?", (product_id,))
        product = cursor.fetchone()
        if not product:
            flash('Product not found', 'error')
            return redirect(url_for('index'))
        conn.close()
        return render_template('customer/product_detail.html', product=product, lang=lang, t=TEXTS.get(lang, TEXTS['am']))
    except Exception as e:
        app.logger.error(f"Product detail error: {str(e)}")
        flash('Unable to load product', 'error')
        return redirect(url_for('index'))


@app.route('/category/<category>')
def category_products(category):
    """Category products page."""
    lang = get_lang()
    # ቋንቋውን አስቀድመን እናዘጋጅ
    safe_t = TEXTS.get(lang, TEXTS.get('am', {}))
    
    try:
        conn = get_db()
        cursor = conn.cursor()
        
        # ደህንነቱ የተጠበቀ የካቴጎሪ ስም
        if category == 'all':
            cursor.execute("SELECT * FROM products ORDER BY id DESC")
            category_name = 'All Products' if lang == 'en' else 'ሁሉም ምርቶች'
        else:
            cursor.execute("SELECT * FROM products WHERE category = ? ORDER BY id DESC", (category,))
            category_name = category
            
        items = cursor.fetchall()
        conn.close()
        
        # ለደህንነት ሲባል ዳታው ባዶ ከሆነ ባዶ ሊስት እንላክ
        if items is None:
            items = []

        return render_template('customer/category.html', 
                               items=items, 
                               category=category_name, 
                               lang=lang, 
                               t=safe_t)
                               
    except Exception as e:
        # ስህተቱን በዝርዝር ለመመዝገብ
        app.logger.error(f"Critical Category error: {str(e)}")
        # በስተት ወቅት ሰርቨሩ እንዳይቆም ወደ ዋና ገጽ መላክ
        return redirect(url_for('index'))

@app.route('/search')
def search():
    """Search products page."""
    lang = get_lang()
    query = request.args.get('q', '').strip()
    if not query:
        return redirect(url_for('index'))
    try:
        conn = get_db()
        cursor = conn.cursor()
        search_pattern = f'%{query}%'
        cursor.execute("SELECT * FROM products WHERE name_am LIKE ? OR name_en LIKE ? ORDER BY id DESC", (search_pattern, search_pattern))
        items = cursor.fetchall()
        conn.close()
        return render_template('customer/search.html', items=items, query=query, lang=lang, t=TEXTS.get(lang, TEXTS['am']))
    except Exception as e:
        app.logger.error(f"Search error: {str(e)}")
        flash('Search failed', 'error')
        return redirect(url_for('index'))


@app.route('/about')
def about():
    """About page."""
    lang = get_lang()
    return render_template('customer/about.html', lang=lang, t=TEXTS.get(lang, TEXTS['am']))


@app.route('/contact', methods=['GET', 'POST'])
def contact():
    """Contact page with WhatsApp integration."""
    lang = get_lang()
    if request.method == 'POST':
        name = request.form.get('name', '').strip()
        email = request.form.get('email', '').strip()
        phone = request.form.get('phone', '').strip()
        message = request.form.get('message', '').strip()
        if not name or not message:
            flash('Please fill in name and message', 'error')
            return redirect(url_for('contact'))
        
        whatsapp_msg = f"📬 New Contact Message\n\nName: {name}\nEmail: {email or 'Not provided'}\nPhone: {phone or 'Not provided'}\n\nMessage:\n{message}"
        encoded = urllib.parse.quote(whatsapp_msg)
        whatsapp_url = f"https://wa.me/{WHATSAPP_NUMBER}?text={encoded}"
        flash('Message sent! Redirecting to WhatsApp...', 'success')
        return redirect(whatsapp_url)
    return render_template('customer/contact.html', lang=lang, t=TEXTS.get(lang, TEXTS['am']))


@app.route('/static/uploads/<path:filename>')
def uploaded_file(filename):
    """Serve uploaded files securely."""
    if '..' in filename or filename.startswith('/'):
        abort(404)
    return send_from_directory(app.config['UPLOAD_FOLDER'], filename)
    # ==================== 7. 🛒 CART ROUTES ====================

# ------------------------------------------------------------------
# View Cart Route
# ------------------------------------------------------------------
@app.route('/cart')
def view_cart():
    """
    Display the shopping cart page.
    Shows all items currently in the user's cart.
    """
    lang = get_lang()
    t = TEXTS.get(lang, TEXTS['am'])
    
    # Get cart from session
    cart = session.get('cart', [])
    
    # Calculate cart totals
    cart_items = []
    subtotal = 0
    
    for item in cart:
        item_total = item.get('price', 0) * item.get('quantity', 1)
        subtotal += item_total
        cart_items.append({
            'id': item.get('id'),
            'name': item.get('name'),
            'price': item.get('price', 0),
            'quantity': item.get('quantity', 1),
            'image': item.get('image', ''),
            'total': item_total
        })
    
    # Calculate shipping (free shipping over 5000 ETB)
    threshold = int(os.environ.get('FREE_SHIPPING_THRESHOLD', '5000'))
    shipping_cost = int(os.environ.get('SHIPPING_COST', '200'))
    shipping = 0 if subtotal >= threshold else shipping_cost
    total = subtotal + shipping
    
    app.logger.info(f"Cart viewed - Items: {len(cart_items)}, Total: {total} ETB")
    
    return render_template('customer/cart.html', 
                           cart_items=cart_items,
                           subtotal=subtotal,
                           shipping=shipping,
                           total=total,
                           lang=lang,
                           t=t)


# ------------------------------------------------------------------
# Add to Cart Route
# ------------------------------------------------------------------
@app.route('/cart/add', methods=['POST'])
def add_to_cart():
    """
    Add a product to the shopping cart.
    Accepts product details via POST request.
    """
    try:
        # Get product details from form
        product_id = request.form.get('product_id')
        product_name = request.form.get('product_name')
        product_price = float(request.form.get('product_price', 0))
        product_image = request.form.get('product_image', '')
        quantity = int(request.form.get('quantity', 1))
        
        # Validate input
        if not product_id or not product_name or product_price <= 0:
            flash('Invalid product information.', 'error')
            return redirect(request.referrer or url_for('index'))
        
        if quantity < 1:
            quantity = 1
        
        # Get current cart from session
        cart = session.get('cart', [])
        
        # Check if product already exists in cart
        found = False
        for item in cart:
            if str(item.get('id')) == str(product_id):
                item['quantity'] += quantity
                found = True
                app.logger.info(f"Updated cart item: {product_name} x{item['quantity']}")
                break
        
        # If product not in cart, add new item
        if not found:
            cart.append({
                'id': str(product_id),
                'name': product_name,
                'price': product_price,
                'quantity': quantity,
                'image': product_image
            })
            app.logger.info(f"Added to cart: {product_name} x{quantity}")
        
        # Save cart back to session
        session['cart'] = cart
        session.modified = True
        
        # Calculate new cart count
        cart_count = sum(item.get('quantity', 1) for item in cart)
        
        # Check if AJAX request
        if request.headers.get('X-Requested-With') == 'XMLHttpRequest':
            return jsonify({
                'success': True,
                'message': f'{product_name} added to cart!',
                'cart_count': cart_count
            })
        
        flash(f'{product_name} added to cart!', 'success')
        return redirect(url_for('view_cart'))
        
    except Exception as e:
        app.logger.error(f"Error adding to cart: {str(e)}")
        if request.headers.get('X-Requested-With') == 'XMLHttpRequest':
            return jsonify({'success': False, 'message': 'Failed to add item to cart.'}), 500
        flash('Failed to add item to cart. Please try again.', 'error')
        return redirect(request.referrer or url_for('index'))


# ------------------------------------------------------------------
# Update Cart Route
# ------------------------------------------------------------------
@app.route('/cart/update', methods=['POST'])
def update_cart():
    """
    Update item quantities in the shopping cart.
    """
    try:
        product_id = request.form.get('product_id')
        quantity = int(request.form.get('quantity', 1))
        
        if not product_id:
            flash('Invalid product information.', 'error')
            return redirect(url_for('view_cart'))
        
        if quantity < 1:
            quantity = 1
        
        # Get current cart
        cart = session.get('cart', [])
        
        # Update quantity
        item_name = None
        for item in cart:
            if str(item.get('id')) == str(product_id):
                item['quantity'] = quantity
                item_name = item.get('name')
                app.logger.info(f"Updated cart: {item_name} x{quantity}")
                break
        
        # Save cart
        session['cart'] = cart
        session.modified = True
        
        # Calculate new totals
        subtotal = 0
        item_total = 0
        for item in cart:
            item_total_calc = item.get('price', 0) * item.get('quantity', 1)
            subtotal += item_total_calc
            if str(item.get('id')) == str(product_id):
                item_total = item_total_calc
        
        threshold = int(os.environ.get('FREE_SHIPPING_THRESHOLD', '5000'))
        shipping_cost = int(os.environ.get('SHIPPING_COST', '200'))
        shipping = 0 if subtotal >= threshold else shipping_cost
        total = subtotal + shipping
        cart_count = sum(item.get('quantity', 1) for item in cart)
        
        # Check if AJAX request
        if request.headers.get('X-Requested-With') == 'XMLHttpRequest':
            return jsonify({
                'success': True,
                'item_total': item_total,
                'subtotal': subtotal,
                'shipping': shipping,
                'total': total,
                'cart_count': cart_count
            })
        
        flash('Cart updated successfully!', 'success')
        return redirect(url_for('view_cart'))
        
    except Exception as e:
        app.logger.error(f"Error updating cart: {str(e)}")
        if request.headers.get('X-Requested-With') == 'XMLHttpRequest':
            return jsonify({'success': False, 'message': 'Failed to update cart.'}), 500
        flash('Failed to update cart. Please try again.', 'error')
        return redirect(url_for('view_cart'))


# ------------------------------------------------------------------
# Remove from Cart Route
# ------------------------------------------------------------------
@app.route('/cart/remove/<item_id>')
def remove_from_cart(item_id):
    """
    Remove an item from the shopping cart.
    
    Args:
        item_id (str): The ID of the item to remove
    """
    try:
        # Get current cart
        cart = session.get('cart', [])
        
        # Find and remove item
        removed_item = None
        new_cart = []
        for item in cart:
            if str(item.get('id')) == str(item_id):
                removed_item = item
            else:
                new_cart.append(item)
        
        # Save updated cart
        session['cart'] = new_cart
        session.modified = True
        
        if removed_item:
            app.logger.info(f"Removed from cart: {removed_item.get('name')}")
            flash(f'{removed_item.get("name")} removed from cart.', 'success')
        else:
            flash('Item not found in cart.', 'warning')
        
        return redirect(url_for('view_cart'))
        
    except Exception as e:
        app.logger.error(f"Error removing from cart: {str(e)}")
        flash('Failed to remove item. Please try again.', 'error')
        return redirect(url_for('view_cart'))


# ------------------------------------------------------------------
# Clear Cart Route
# ------------------------------------------------------------------
@app.route('/cart/clear')
def clear_cart():
    """
    Clear all items from the shopping cart.
    """
    try:
        # Get cart size before clearing
        cart = session.get('cart', [])
        item_count = len(cart)
        
        # Clear cart
        session['cart'] = []
        session.modified = True
        
        app.logger.info(f"Cart cleared - Removed {item_count} items")
        flash('Cart has been cleared.', 'success')
        
        return redirect(url_for('view_cart'))
        
    except Exception as e:
        app.logger.error(f"Error clearing cart: {str(e)}")
        flash('Failed to clear cart. Please try again.', 'error')
        return redirect(url_for('view_cart'))


# ------------------------------------------------------------------
# Checkout Route
# ------------------------------------------------------------------
@app.route('/checkout', methods=['GET', 'POST'])
def checkout():
    """
    Checkout page - Collect customer information and process order.
    """
    lang = get_lang()
    t = TEXTS.get(lang, TEXTS['am'])
    
    # Get cart from session
    cart = session.get('cart', [])
    
    # Check if cart is empty
    if not cart:
        flash('Your cart is empty. Please add some items before checkout.', 'warning')
        return redirect(url_for('view_cart'))
    
    # Calculate totals
    subtotal = 0
    for item in cart:
        subtotal += item.get('price', 0) * item.get('quantity', 1)
    
    threshold = int(os.environ.get('FREE_SHIPPING_THRESHOLD', '5000'))
    shipping_cost = int(os.environ.get('SHIPPING_COST', '200'))
    shipping = 0 if subtotal >= threshold else shipping_cost
    total = subtotal + shipping
    
    if request.method == 'POST':
        try:
            # Get customer information
            customer_name = request.form.get('customer_name', '').strip()
            customer_phone = request.form.get('customer_phone', '').strip()
            customer_address = request.form.get('customer_address', '').strip()
            customer_email = request.form.get('customer_email', '').strip()
            order_notes = request.form.get('order_notes', '').strip()
            
            # Validate required fields
            if not customer_name or not customer_phone:
                flash('Please fill in your name and phone number.', 'error')
                return redirect(url_for('checkout'))
            
            # Prepare order message for WhatsApp
            order_message = "🛍️ *NEW ORDER - Ethiosadat Furniture*\n"
            order_message += "=" * 40 + "\n\n"
            order_message += f"👤 *Customer Name:* {customer_name}\n"
            order_message += f"📞 *Phone:* {customer_phone}\n"
            if customer_address:
                order_message += f"📍 *Address:* {customer_address}\n"
            if customer_email:
                order_message += f"📧 *Email:* {customer_email}\n"
            if order_notes:
                order_message += f"📝 *Notes:* {order_notes}\n"
            
            order_message += "\n" + "=" * 40 + "\n"
            order_message += "🛒 *ORDER ITEMS:*\n"
            order_message += "-" * 30 + "\n"
            
            for item in cart:
                item_name = item.get('name', 'Unknown')
                item_price = item.get('price', 0)
                item_qty = item.get('quantity', 1)
                item_total = item_price * item_qty
                order_message += f"• {item_name}\n"
                order_message += f"  {item_price} ETB x {item_qty} = {item_total} ETB\n"
            
            order_message += "-" * 30 + "\n"
            order_message += f"💰 *Subtotal:* {subtotal} ETB\n"
            order_message += f"🚚 *Shipping:* {shipping} ETB\n"
            order_message += "=" * 30 + "\n"
            order_message += f"💵 *TOTAL:* {total} ETB\n"
            order_message += "=" * 30 + "\n\n"
            order_message += "🙏 Thank you for shopping with Ethiosadat!"
            
            # Encode message for WhatsApp
            encoded_message = urllib.parse.quote(order_message)
            whatsapp_url = f"https://wa.me/{WHATSAPP_NUMBER}?text={encoded_message}"
            
            # Clear cart after successful order
            session['cart'] = []
            session.modified = True
            
            app.logger.info(f"Order placed by {customer_name} - Total: {total} ETB")
            flash('Your order has been placed successfully! You will be redirected to WhatsApp.', 'success')
            
            return redirect(whatsapp_url)
            
        except Exception as e:
            app.logger.error(f"Error processing checkout: {str(e)}")
            flash('An error occurred while processing your order. Please try again.', 'error')
            return redirect(url_for('checkout'))
    
    # GET request - show checkout form
    return render_template('customer/checkout.html',
                           cart=cart,
                           subtotal=subtotal,
                           shipping=shipping,
                           total=total,
                           lang=lang,
                           t=t)


