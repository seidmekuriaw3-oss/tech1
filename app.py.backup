@app.route('/admin/reports')
def admin_reports():
    """
    Reports dashboard - View sales and product statistics.
    """
    if not session.get('admin'):
        return redirect(url_for('login'))
    
    lang = get_lang()
    t = TEXTS.get(lang, TEXTS['am'])
    
    try:
        conn = get_db()
        cursor = conn.cursor()
        
        # Get counts
        cursor.execute("SELECT COUNT(*) FROM products")
        total_products = cursor.fetchone()[0]
        
        cursor.execute("SELECT COUNT(*) FROM orders")
        total_orders = cursor.fetchone()[0]
        
        # Get category distribution
        cursor.execute("SELECT category, COUNT(*) FROM products WHERE category IS NOT NULL GROUP BY category")
        categories = cursor.fetchall()
        
        # Calculate total revenue from delivered orders
        cursor.execute("SELECT SUM(total) FROM orders WHERE status = 'delivered'")
        total_revenue = cursor.fetchone()[0] or 0
        
        # Get pending orders count
        cursor.execute("SELECT COUNT(*) FROM orders WHERE status = 'pending'")
        pending_orders = cursor.fetchone()[0]
        
        conn.close()
        
        app.logger.info("Admin reports viewed")
        
        return render_template('admin/reports/index.html',
                               total_products=total_products,
                               total_orders=total_orders,
                               total_revenue=total_revenue,
                               pending_orders=pending_orders,
                               categories=categories,
                               lang=lang, t=t)
    
    except Exception as e:
        app.logger.error(f"Error loading reports: {str(e)}")
        flash('Error loading reports.', 'error')
        return redirect(url_for('admin_dashboard'))


