        flash('Error loading products.', 'error')
        return redirect(url_for('admin_dashboard'))


@app.route('/admin/products/add', methods=['GET', 'POST'])
def admin_add_product():
    """
    Add new product - GET: Show form, POST: Process form data.
    """
    if not session.get('admin'):
        return redirect(url_for('login'))
    
    lang = get_lang()
    t = TEXTS.get(lang, TEXTS['am'])
    
    if request.method == 'POST':
        try:
            # ከፎርሙ መረጃዎችን መሰብሰብ
            name_am = request.form.get('name_am', '').strip()
            name_en = request.form.get('name_en', '').strip()
            desc_am = request.form.get('description_am', '').strip()
            desc_en = request.form.get('description_en', '').strip()
            price = request.form.get('price', '0').strip()
            old_price = request.form.get('old_price', '0').strip()
            category = request.form.get('category', 'ሌላ')
            stock = request.form.get('stock_quantity', 0)
            featured = 1 if request.form.get('is_featured') else 0
            m_title = request.form.get('meta_title', '').strip()
            m_desc = request.form.get('meta_description', '').strip()
            
            # የግድ የሚያስፈልጉ መረጃዎችን መፈተሽ
            if not name_am or not price:
                flash('Please fill in all required fields.', 'error')
                return redirect(url_for('admin_add_product'))
            
            # ምስልን ማስተናገድ
            image_file = request.files.get('image')
            image_filename = ''
            
            if image_file and image_file.filename:
                if allowed_file(image_file.filename):
                    ext = image_file.filename.rsplit('.', 1)[1].lower()
                    image_filename = f"{uuid.uuid4().hex}_{datetime.now().strftime('%Y%m%d%H%M%S')}.{ext}"
                    upload_path = os.path.join(app.config['UPLOAD_FOLDER'], 'products')
                    os.makedirs(upload_path, exist_ok=True)
                    image_file.save(os.path.join(upload_path, image_filename))
                else:
                    flash('Invalid file type.', 'error')
                    return redirect(url_for('admin_add_product'))
            
            # ወደ ዳታቤዝ ማስገባት (ከአዲሱ Table Schema ጋር የተጣጣመ)
            conn = get_db()
            cursor = conn.cursor()
            cursor.execute("""
                INSERT INTO products (
                    name_am, name_en, description_am, description_en, 
                    price, old_price, category, stock_quantity, 
                    is_featured, image, meta_title, meta_description
                ) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)
            """, (name_am, name_en, desc_am, desc_en, price, old_price, 
                  category, stock, featured, image_filename, m_title, m_desc))
            conn.commit()
            conn.close()
            
            flash(f'Product "{name_am}" added successfully!', 'success')
            return redirect(url_for('admin_products'))
            
        except Exception as e:
            app.logger.error(f"Error adding product: {str(e)}")
            flash('Error adding product.', 'error')
            return redirect(url_for('admin_add_product'))
    
    return render_template('admin/products/add.html', lang=lang, t=t)


@app.route('/admin/products/edit/<int:pid>', methods=['GET', 'POST'])
def admin_edit_product(pid):
    """
    Edit product - GET: Show form, POST: Update product.
    """
    if not session.get('admin'):
        return redirect(url_for('login'))
    
    lang = get_lang()
    t = TEXTS.get(lang, TEXTS['am'])
    
    try:
        conn = get_db()
        conn.row_factory = sqlite3.Row # መረጃውን በስም ለመጥራት
        cursor = conn.cursor()
        cursor.execute("SELECT * FROM products WHERE id = ?", (pid,))
        product = cursor.fetchone()
        
        if not product:
            conn.close()
            flash('Product not found.', 'error')
            return redirect(url_for('admin_products'))
        
        if request.method == 'POST':
            name_am = request.form.get('name_am', '').strip()
            name_en = request.form.get('name_en', '').strip()
            desc_am = request.form.get('description_am', '').strip()
            desc_en = request.form.get('description_en', '').strip()
            price = request.form.get('price', '0').strip()
            old_price = request.form.get('old_price', '0').strip()
            category = request.form.get('category', 'ሌላ')
            stock = request.form.get('stock_quantity', 0)
            featured = 1 if request.form.get('is_featured') else 0
            
            # ምስል መቀየር ካለ
            image_file = request.files.get('image')
            image_filename = product['image'] # የቆየውን ምስል መያዝ
            
            if image_file and image_file.filename:
                if allowed_file(image_file.filename):
                    # የድሮውን ምስል ማጥፋት
                    if image_filename:
                        old_path = os.path.join(app.config['UPLOAD_FOLDER'], 'products', image_filename)
                        if os.path.exists(old_path):
                            os.remove(old_path)
                    
                    # አዲሱን ምስል ማስቀመጥ
                    ext = image_file.filename.rsplit('.', 1)[1].lower()
                    image_filename = f"{uuid.uuid4().hex}_{datetime.now().strftime('%Y%m%d%H%M%S')}.{ext}"
                    upload_path = os.path.join(app.config['UPLOAD_FOLDER'], 'products')
                    image_file.save(os.path.join(upload_path, image_filename))
            
            # ዳታቤዙን ማዘመን
            cursor.execute("""
                UPDATE products 
                SET name_am=?, name_en=?, description_am=?, description_en=?, 
                    price=?, old_price=?, category=?, stock_quantity=?, 
                    is_featured=?, image=?
                WHERE id=?
            """, (name_am, name_en, desc_am, desc_en, price, old_price, 
                  category, stock, featured, image_filename, pid))
            conn.commit()
            conn.close()
            
            flash(f'Product "{name_am}" updated successfully!', 'success')
            return redirect(url_for('admin_products'))
        
        conn.close()
        return render_template('admin/products/edit.html', product=product, lang=lang, t=t)
    
    except Exception as e:
        app.logger.error(f"Error editing product {pid}: {str(e)}")
        flash('Error editing product.', 'error')
        return redirect(url_for('admin_products'))

@app.route('/admin/products/delete/<int:pid>')
def admin_delete_product(pid):
    """
    Delete product - Remove product from database and delete image.
    
    Args:
        pid (int): Product ID
    """
    if not session.get('admin'):
        return redirect(url_for('login'))
    
    try:
        conn = get_db()
        cursor = conn.cursor()
        
        # Get product image before deleting
        cursor.execute("SELECT name_am, image FROM products WHERE id = ?", (pid,))
        product = cursor.fetchone()
        
        if product:
            # Delete image file if exists
            if product[1]:
                image_path = os.path.join(app.config['UPLOAD_FOLDER'], 'products', product[1])
                if os.path.exists(image_path):
                    os.remove(image_path)
                    app.logger.info(f"Deleted product image: {product[1]}")
            
            # Delete from database
            cursor.execute("DELETE FROM products WHERE id = ?", (pid,))
            conn.commit()
            
            app.logger.info(f"Product deleted: ID {pid} - {product[0]}")
            flash(f'Product "{product[0]}" deleted successfully!', 'success')
        else:
            flash('Product not found.', 'error')
        
        conn.close()
        return redirect(url_for('admin_products'))
    
    except Exception as e:
        app.logger.error(f"Error deleting product {pid}: {str(e)}")
        flash('Error deleting product.', 'error')
        return redirect(url_for('admin_products'))
