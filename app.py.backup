# ------------------------------------------------------------------
# Admin Dashboard
# ------------------------------------------------------------------
@app.route('/admin')
def admin_dashboard():
    """
    Admin dashboard - Main admin panel with statistics.
    Displays overview of products and ads.
    """
    # Check if user is logged in as admin
    if not session.get('admin'):
        flash('Please log in to access the admin panel.', 'warning')
        return redirect(url_for('login'))
    
    lang = get_lang()
    t = TEXTS.get(lang, TEXTS['am'])
    
    try:
        conn = get_db()
        cursor = conn.cursor()
        
        # Get counts
        cursor.execute("SELECT COUNT(*) FROM products")
        products_count = cursor.fetchone()[0]
        
        cursor.execute("SELECT COUNT(*) FROM ads")
        ads_count = cursor.fetchone()[0]
        
        # Get recent products (last 5)
        cursor.execute("SELECT * FROM products ORDER BY id DESC LIMIT 5")
        recent_products = cursor.fetchall()
        
        # Get recent ads (last 5)
        cursor.execute("SELECT * FROM ads ORDER BY id DESC LIMIT 5")
        recent_ads = cursor.fetchall()
        
        conn.close()
        
        app.logger.info(f"Admin dashboard accessed - Products: {products_count}, Ads: {ads_count}")
        
        return render_template('admin/dashboard.html',
                               products_count=products_count,
                               ads_count=ads_count,
                               recent_products=recent_products,
                               recent_ads=recent_ads,
                               lang=lang,
                               t=t)
    
    except Exception as e:
        app.logger.error(f"Error loading admin dashboard: {str(e)}")
        flash('Error loading dashboard data.', 'error')
        return render_template('admin/dashboard.html', 
                               products_count=0, ads_count=0, 
                               recent_products=[], recent_ads=[],
                               lang=lang, t=t)


